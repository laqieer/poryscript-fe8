    "flashcursor": { "macro": "FlashCursor", "args": [0, 1] },
    "sleep":       { "macro": "STAL" },
    "text":        { "macro": "Text" },
    "textbg":      { "macro": "Text_BG", "args": [0, 1] },
    "asmcall":     { "macro": "ASMC" },
    "checkflag":   { "macro": "CHECK_EVENTID" },
    "nofade":      { "macro": "NoFade" }
