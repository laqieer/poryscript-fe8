{
  "array_type": "EventListScr",
  "call_command": "call",
  "call_macro": "CALL",
  "header_includes": [
    "global.h",
    "bmunit.h",
    "event.h",
    "eventinfo.h",
    "eventcall.h",
    "EAstdlib.h",
    "constants/characters.h",
    "constants/backgrounds.h",
    "constants/items.h",
    "constants/songs.h",
    "constants/chapters.h"
  ],
  "commands": {
    "playbgm":     { "macro": "MUSC" },
    "fadeout":     { "macro": "FADU" },
    "fadein":      { "macro": "FADI" },
    "loadunits":   { "macro": "LOAD1", "args": [0, 1] },
    "loadunits2":  { "macro": "LOAD2", "args": [0, 1] },
    "wait":        { "macro": "ENUN" },
    "setflag":     { "macro": "ENUT" },
    "clearflag":   { "macro": "ENUF" },
